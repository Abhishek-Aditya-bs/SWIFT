{
  "name": "swift-website",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "Marketing website for SWIFT — lightweight image super-resolution. Single-page Vite + React + Tailwind. Deploys to Cloudflare Pages.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4175",
    "lint": "tsc --noEmit",
    "deploy": "npm run build && npx wrangler pages deploy dist --project-name=swift-website"
  },
  "dependencies": {
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/inter": "^5.2.8",
    "@fontsource/jetbrains-mono": "^5.1.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  }
}
